# ============================================================
# TREAD Project .gitignore
# ============================================================

# ── highD 原始数据 (4.5GB+) ──────────────────────────────
highD_dataset/Matlab/data/
highD_dataset/Matlab/data/.~lock.*

# ── Matlab 中间数据和结果 (~800MB) ───────────────────────
highD_dataset/Matlab/bin/*.mat
highD_dataset/Matlab/测试数据及处理算法/
highD_dataset/Matlab/visualization/*.fig

# ── Matlab / Excel 二进制数据 ────────────────────────────
*.fig
*.xls
*.xlsx

# ── TREAD 处理后输出 (H5/CSV/图表) ──────────────────────
/references/

# ── 论文 PDF ────────────────────────────────────────────
references/*.pdf

# ── Simulink 模型 (二进制) ──────────────────────────────
/ACC_ADST/
/archives/

# ── Python 通用 ─────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
/data/**/*.npy
/data/**/*.npz
/data/**/*.h5
/data/**/*.hdf5
/data/**/*.parquet
/data/**/*.pkl
/data/**/*.joblib
*.egg-info/
dist/
build/
*.egg
.pytest_cache/
.tox/
.coverage
htmlcov/

# ── 模型权重、训练日志和实验输出 ─────────────────────────
/data/**/*.pt
/data/**/*.pth
/data/**/*.ckpt
/data/**/*.onnx
**/checkpoints/
**/runs/
**/.plot_cache/
wandb/
mlruns/
lightning_logs/
outputs/
results/
/data/**/*.log

# ── 虚拟环境 ────────────────────────────────────────────
venv/
.venv/
env/

# ── IDE ─────────────────────────────────────────────────
.idea/
.vscode/
.agents/
.claude/
.codex/
*.swp
*.swo
*~
.DS_Store

# ── Jupyter ─────────────────────────────────────────────
.ipynb_checkpoints/

# ── OS ──────────────────────────────────────────────────
Thumbs.db
.DS_Store
