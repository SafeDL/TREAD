# ============================================================
# TREAD Project .gitignore
# ============================================================

# ── highD 原始数据和 Matlab 产物 ─────────────────────────
highD_dataset/Matlab/data/
highD_dataset/Matlab/data/.~lock.*
highD_dataset/Matlab/bin/*.mat
highD_dataset/Matlab/测试数据及处理算法/
highD_dataset/Matlab/visualization/*.fig

# ── Matlab / Excel / Simulink 二进制文件 ────────────────
*.fig
*.xls
*.xlsx
*.slx

# ── TREAD 数据、论文材料和实验输出 ──────────────────────
/references/
/outputs/
/results/
/runs/
/wandb/
/mlruns/
/lightning_logs/

# data/ 下允许提交小型 CSV/JSON/schema 等元数据；只忽略大型或可再生成产物。
/data/**/checkpoints/
/data/**/ckpt/
/data/**/runs/
/data/**/.plot_cache/
/data/**/*.pt
/data/**/*.pth
/data/**/*.ckpt
/data/**/*.onnx
/data/**/*.npy
/data/**/*.npz
/data/**/*dataset*.npz
/data/**/*.h5
/data/**/*.hdf5
/data/**/*.parquet
/data/**/*.pkl
/data/**/*.joblib
/data/**/*.log
/data/**/*.tfevents*
/data/**/events.out.tfevents.*

# 训练/评估产物：保留 schema/stats 和实验结果图，其余可再生成报告默认忽略。
/data/**/training_history.csv
/data/**/training_history.json
/data/**/training_summary.json
/data/**/naturalness_metrics.csv
/data/**/naturalness_summary.json
/data/**/diversity_summary.json
/data/**/natural_rollouts_summary.json
/data/**/discriminator_build_summary.json
/data/**/discriminator_eval_summary.json
/data/**/source_wise_metrics.csv

# adversaray 下的判别器/引导采样大数据可再生成，继续忽略；
# 但 schema、stats、summary、metrics、图表和简短测试结果允许提交。
/data/adversaray/**/checkpoints/
/data/adversaray/**/ckpt/
/data/adversaray/**/runs/
/data/adversaray/**/.plot_cache/
/data/adversaray/**/*.pt
/data/adversaray/**/*.pth
/data/adversaray/**/*.ckpt
/data/adversaray/**/*.onnx
/data/adversaray/**/*.npy
/data/adversaray/**/*.npz
/data/adversaray/**/*.h5
/data/adversaray/**/*.hdf5
/data/adversaray/**/*.parquet
/data/adversaray/**/*.pkl
/data/adversaray/**/*.joblib
/data/adversaray/**/*.log
/data/adversaray/**/*.tfevents*
/data/adversaray/**/events.out.tfevents.*
!/data/adversaray/**/*.json
!/data/adversaray/**/*.csv
!/data/adversaray/**/*.md
!/data/adversaray/**/*.txt
!/data/adversaray/**/*.yaml
!/data/adversaray/**/*.yml
!/data/adversaray/**/*.png
!/data/adversaray/**/*.jpg
!/data/adversaray/**/*.jpeg
!/data/adversaray/**/*.svg

# 保留 archives 中的历史源码，只忽略其中可再生成的产物。
/archives/

# ── Python 通用 ─────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
.pytest_cache/
.tox/
.coverage
htmlcov/

# ── 常见训练目录 ────────────────────────────────────────
**/checkpoints/
**/ckpt/
**/.plot_cache/

# ── 虚拟环境 ────────────────────────────────────────────
venv/
.venv/
env/

# ── IDE ─────────────────────────────────────────────────
.idea/
.vscode/
.agents/
.claude/
.codex/
*.swp
*.swo
*~

# ── Jupyter ─────────────────────────────────────────────
.ipynb_checkpoints/

# ── OS ──────────────────────────────────────────────────
Thumbs.db
.DS_Store
